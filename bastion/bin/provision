#!/usr/bin/env python3
"""
gpsaml-proxy provision helper.

Brings a per-user GlobalProtect tunnel up (or down) on the bastion. The
web service invokes this with `sudo -n /opt/gpsaml-proxy/bin/provision
<up|down|heartbeat> <user> [...]` per a NOPASSWD entry in
/etc/sudoers.d/gpsaml-proxy.

`up` writes the freshly-generated SSH private key to stdout. The web is
expected to capture stdout, hand the key to the browser, and never
persist it.
"""

import argparse
import fcntl
import json
import os
import pathlib
import pwd
import re
import shutil
import subprocess
import sys
import tempfile
import time

# ── config ──────────────────────────────────────────────────────────
USER_RE = re.compile(r"^[a-z][a-z0-9_-]{1,30}$")
GROUP = "gpsaml-users"
QUOTA = 250
SUBNET_BASE = "10.200"  # /16 sliced into /30s under .{octet}.0/30
STATE_DIR = pathlib.Path("/var/lib/gpsaml-proxy")
RUNTIME_DIR = pathlib.Path("/var/run/gpsaml-proxy")
SUDOERS_DIR = pathlib.Path("/etc/sudoers.d")
NETNS_ETC = pathlib.Path("/etc/netns")
HOME_BASE = pathlib.Path("/home")

OPENCONNECT = "/usr/local/sbin/openconnect"
HIPREPORT = "/usr/local/libexec/openconnect/hipreport.sh"
VPNC_WRAPPER = "/opt/gpsaml-proxy/bin/vpnc-script-netns"
ENTER_NS = "/opt/gpsaml-proxy/bin/enter-ns"
IP = "/usr/sbin/ip"
IPTABLES = "/usr/sbin/iptables"
USERADD = "/usr/sbin/useradd"
USERMOD = "/usr/sbin/usermod"
GROUPADD = "/usr/sbin/groupadd"
SSH_KEYGEN = "/usr/bin/ssh-keygen"
VISUDO = "/usr/sbin/visudo"
SOCAT = "/usr/bin/socat"
FORWARDS_CONFIG = pathlib.Path("/etc/gpsaml-proxy/forwards.json")


# ── small helpers ───────────────────────────────────────────────────
_T0 = time.monotonic()
LOG_PATH = pathlib.Path("/var/log/gpsaml-proxy/provision.log")
_PID = os.getpid()


def trace(msg: str) -> None:
    """Timestamped trace, written to BOTH stderr and a persistent log
    file. Stderr alone gets lost when the web's subprocess.run hits its
    TimeoutExpired before we finish — the captured-but-undelivered
    stderr never reaches Flask's exception handler. Writing straight to
    /var/log/gpsaml-proxy/provision.log means trace lines survive
    regardless of how the parent disposes of us."""
    line = f"[{time.monotonic() - _T0:6.2f}s pid={_PID}] {msg}\n"
    try:
        sys.stderr.write(line)
        sys.stderr.flush()
    except Exception:
        pass
    try:
        LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
        with LOG_PATH.open("a") as fh:
            fh.write(line)
    except Exception:
        pass


def run(*args, check=True, capture=False, env=None):
    kw = {"check": check, "env": env}
    if capture:
        kw.update(stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
    return subprocess.run(list(args), **kw)


def egress_iface() -> str:
    out = subprocess.check_output([IP, "route", "show", "default"], text=True)
    return out.split()[4]  # default via X dev <iface> ...


def assert_user(user: str) -> None:
    if not USER_RE.match(user):
        sys.exit(f"bad username: {user!r}")


def ns_for(user: str) -> str:
    return f"ns_{user}"


# ── subnet allocator ────────────────────────────────────────────────
# Persists to /var/lib/gpsaml-proxy/subnet-map.json. Holds an exclusive
# flock for the duration of read-modify-write.
def _state_path() -> pathlib.Path:
    return STATE_DIR / "subnet-map.json"


def _with_state(fn):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    p = _state_path()
    p.touch(exist_ok=True)
    with open(p, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            try:
                state = json.loads(f.read() or '{"users":{},"free":[]}')
            except json.JSONDecodeError:
                state = {"users": {}, "free": []}
            new_state, ret = fn(state)
            if new_state is not None:
                f.seek(0)
                f.truncate()
                f.write(json.dumps(new_state, indent=2, sort_keys=True))
                f.flush()
            return ret
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


def acquire_subnet(user: str):
    def go(state):
        if user in state["users"]:
            return None, state["users"][user]
        if len(state["users"]) >= QUOTA:
            sys.exit(3)  # convention: exit 3 == quota exhausted
        if state["free"]:
            state["free"].sort()
            octet = state["free"].pop(0)
        else:
            used = set(state["users"].values()) | set(state["free"])
            octet = next(o for o in range(2, 252) if o not in used)
        state["users"][user] = octet
        return state, octet

    octet = _with_state(go)
    return octet, f"{SUBNET_BASE}.{octet}.1", f"{SUBNET_BASE}.{octet}.2"


def lookup_subnet(user: str):
    return _with_state(lambda s: (None, s["users"].get(user)))


def release_subnet(user: str):
    def go(state):
        if user not in state["users"]:
            return None, None
        octet = state["users"].pop(user)
        if octet not in state["free"]:
            state["free"].append(octet)
        return state, octet

    return _with_state(go)


# ── group / user ────────────────────────────────────────────────────
def ensure_group():
    run(GROUPADD, "-r", "-f", GROUP, capture=True, check=False)


def user_exists(user: str) -> bool:
    try:
        pwd.getpwnam(user)
        return True
    except KeyError:
        return False


def ensure_user(user: str):
    # /bin/bash, not /usr/sbin/nologin — sshd's `command="…"` won't fire
    # for nologin shells (it prints "This account is currently not
    # available." and exits). Security comes from `restrict,…,command=`
    # in authorized_keys + the per-user sudoers scope, not the shell.
    if not user_exists(user):
        run(USERADD, "-m", "-s", "/bin/bash", "-g", GROUP, user)
        return
    # User exists. Skip usermod if they're already in GROUP — usermod
    # refuses to modify a user with an active session, and we don't
    # need to touch the group anyway in the steady-state reconnect path.
    info = subprocess.run(
        ["/usr/bin/id", "-nG", user],
        capture_output=True, text=True, check=False,
    )
    groups = info.stdout.split() if info.returncode == 0 else []
    if GROUP not in groups:
        run(USERMOD, "-aG", GROUP, user, capture=True)


# ── ssh keys / authorized_keys ──────────────────────────────────────
def gen_keypair(user: str):
    td = tempfile.mkdtemp(dir="/tmp")
    try:
        priv = pathlib.Path(td) / "id"
        run(
            SSH_KEYGEN,
            "-t", "ed25519",
            "-N", "",
            "-C", f"gpsaml-proxy@{user}@{int(time.time())}",
            "-f", str(priv),
            "-q",
        )
        return priv.read_text(), priv.with_suffix(".pub").read_text().strip()
    finally:
        shutil.rmtree(td, ignore_errors=True)


def write_authorized_keys(user: str, pub_key_line: str, ns: str):
    home = HOME_BASE / user
    ssh_dir = home / ".ssh"
    ssh_dir.mkdir(mode=0o700, exist_ok=True)
    shutil.chown(ssh_dir, user, GROUP)

    # We want local port forwarding (`ssh -L`) to the user's netns
    # veth IP. `restrict` implies `no-port-forwarding`, and
    # `permitopen="*:*"` is not a real wildcard — sshd treats it
    # as a literal hostname, so any -L channel gets
    # "administratively prohibited". Drop `restrict` and list
    # individual hardenings that don't touch forwarding.
    #
    # Security still holds: the ForceCommand pins the user's session
    # into ns_<user>, the veth network only reaches the user's own
    # tun0, and the laptop side authenticates with a one-shot key.
    options = (
        'no-pty,no-agent-forwarding,no-X11-forwarding,no-user-rc,'
        f'command="{ENTER_NS} {ns}"'
    )
    content = (
        f"# Generated by gpsaml-proxy at "
        f"{time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())}\n"
        f"{options} {pub_key_line}\n"
    )
    auth_keys = ssh_dir / "authorized_keys"
    auth_keys.write_text(content)
    auth_keys.chmod(0o600)
    shutil.chown(auth_keys, user, GROUP)


def blank_authorized_keys(user: str):
    auth_keys = HOME_BASE / user / ".ssh" / "authorized_keys"
    if auth_keys.exists():
        auth_keys.write_text("")


# ── per-user sudoers ────────────────────────────────────────────────
def write_sudoers(user: str, ns: str):
    SUDOERS_DIR.mkdir(parents=True, exist_ok=True)
    path = SUDOERS_DIR / f"gpsaml-user-{user}"
    content = (
        "# Auto-generated by gpsaml-proxy. Do not edit by hand.\n"
        f"{user} ALL=(root) NOPASSWD: {IP} netns exec {ns} *\n"
    )
    tmp = SUDOERS_DIR / f".gpsaml-user-{user}.tmp"
    tmp.write_text(content)
    tmp.chmod(0o440)
    res = run(VISUDO, "-cf", str(tmp), capture=True, check=False)
    if res.returncode != 0:
        tmp.unlink(missing_ok=True)
        sys.exit(f"sudoers syntax check failed: {res.stderr}")
    tmp.replace(path)


def remove_sudoers(user: str):
    (SUDOERS_DIR / f"gpsaml-user-{user}").unlink(missing_ok=True)


# ── networking ──────────────────────────────────────────────────────
def ensure_ip_forward():
    pathlib.Path("/proc/sys/net/ipv4/ip_forward").write_text("1\n")


def ensure_netns(ns: str):
    out = subprocess.check_output([IP, "netns", "list"], text=True)
    existing = {line.split()[0] for line in out.splitlines() if line.strip()}
    if ns in existing:
        return
    run(IP, "netns", "add", ns)


def del_netns(ns: str):
    run(IP, "netns", "del", ns, check=False, capture=True)


def setup_veth(user: str, ns: str, host_ip: str, ns_ip: str):
    veth_h = f"veth_{user}"
    veth_n = f"vp_{user}"
    # Drop any stale leftover
    run(IP, "link", "del", veth_h, check=False, capture=True)
    run(IP, "link", "add", veth_h, "type", "veth", "peer", "name", veth_n,
        "netns", ns)
    run(IP, "addr", "replace", f"{host_ip}/30", "dev", veth_h)
    run(IP, "link", "set", veth_h, "up")
    run(IP, "-n", ns, "addr", "replace", f"{ns_ip}/30", "dev", veth_n)
    run(IP, "-n", ns, "link", "set", veth_n, "up")
    run(IP, "-n", ns, "link", "set", "lo", "up")
    run(IP, "-n", ns, "route", "replace", "default", "via", host_ip)


def remove_veth(user: str):
    run(IP, "link", "del", f"veth_{user}", check=False, capture=True)


def ensure_nat(octet: int):
    cidr = f"{SUBNET_BASE}.{octet}.0/30"
    egress = egress_iface()
    chk = run(IPTABLES, "-t", "nat", "-C", "POSTROUTING",
              "-s", cidr, "-o", egress, "-j", "MASQUERADE",
              check=False, capture=True)
    if chk.returncode != 0:
        run(IPTABLES, "-t", "nat", "-A", "POSTROUTING",
            "-s", cidr, "-o", egress, "-j", "MASQUERADE")


def remove_nat(octet: int):
    cidr = f"{SUBNET_BASE}.{octet}.0/30"
    egress = egress_iface()
    run(IPTABLES, "-t", "nat", "-D", "POSTROUTING",
        "-s", cidr, "-o", egress, "-j", "MASQUERADE",
        check=False, capture=True)


# ── openconnect ─────────────────────────────────────────────────────
def spawn_openconnect(user: str, ns: str, cookie: str, gateway: str,
                     fingerprint: str) -> bool:
    """
    Returns True iff a tun device shows up inside the namespace within
    the deadline. The openconnect process is left running in the
    background (it will daemonize itself with --background); we don't
    block on its parent's exit because some openconnect builds linger
    in the foreground for a few extra seconds after writing the pid
    file, which used to make the web's call_provision time out long
    after the tunnel was actually usable.
    """
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    pid_file = RUNTIME_DIR / f"{user}.pid"
    pid_file.unlink(missing_ok=True)

    env = dict(os.environ)
    env["NETNS_NAME"] = ns

    cmd = [
        IP, "netns", "exec", ns,
        OPENCONNECT,
        "--protocol=gp",
        "-u", user,
        "--os=linux",
        "--useragent=PAN GlobalProtect",
        f"--cookie={cookie}",
        "--version-string=Ubuntu Linux",
        "--servercert", fingerprint,
        f"--csd-wrapper={HIPREPORT}",
        f"--script={VPNC_WRAPPER}",
        "--background",
        f"--pid-file={pid_file}",
        "--syslog",
        gateway,
    ]

    trace(f"spawn_openconnect: launching openconnect (gateway={gateway})")
    # CRITICAL: redirect stdin/stdout/stderr to /dev/null instead of
    # inheriting from provision. openconnect --background daemonizes
    # via fork; the daemon child inherits these fds. If they point to
    # the pipe gunicorn's subprocess.run() set up to capture our
    # stdout, the daemon keeps the pipe's write end open and gunicorn
    # blocks in read() waiting for EOF — provision exits, daemon keeps
    # fd alive, gunicorn finally trips its 300s timeout. With DEVNULL
    # the daemon inherits closed/null fds and our stdout pipe closes
    # cleanly when provision exits. (--syslog is enough for openconnect
    # to log to journal anyway.)
    proc = subprocess.Popen(
        cmd,
        env=env,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        close_fds=True,
        start_new_session=True,
    )

    # Poll for either: tun device up inside the ns (success) OR the
    # openconnect parent exiting non-zero (auth fail, HIP segfault, …).
    # 60s isn't always enough — first observed successful run took ~168s
    # end-to-end (HIP submission to a remote PAN gateway is the long
    # pole). Budget 150s here; web's call_provision timeout (300s) sits
    # on top of this with room for cmd_down rollback and setup.
    deadline = time.time() + 150.0
    last_log = time.time()
    while time.time() < deadline:
        time.sleep(0.5)
        rc = proc.poll()
        if rc is not None and rc != 0:
            trace(f"spawn_openconnect: openconnect parent exited rc={rc}")
            return False
        if time.time() - last_log >= 10.0:
            last_log = time.time()
            trace(
                f"spawn_openconnect: still waiting "
                f"(elapsed={int(time.time() - (deadline - 150))}s, "
                f"pid_file={pid_file.exists()}, parent_rc={rc})"
            )
        if not pid_file.exists():
            continue
        link_show = subprocess.run(
            [IP, "-n", ns, "link", "show"],
            capture_output=True, text=True, check=False,
            timeout=5,
        )
        if link_show.returncode != 0:
            trace(f"spawn_openconnect: ip link show rc={link_show.returncode} stderr={link_show.stderr!r}")
            continue
        if "tun0" in link_show.stdout or "utun" in link_show.stdout:
            trace(f"spawn_openconnect: tun0 detected; pid_file_pid={pid_file.read_text().strip()}")
            return True

    trace("spawn_openconnect: deadline hit, no tun0; killing parent")
    try:
        proc.kill()
    except OSError:
        pass
    return False


def kill_openconnect(user: str):
    """Kill any openconnect for `user`. Tries the pidfile first, then
    sweeps process table for orphans (previous runs killed mid-flight by
    the web's subprocess timeout leak daemonized openconnects that the
    pidfile alone won't catch — the next `up` would see them piling up
    in the user's netns)."""
    pid_file = RUNTIME_DIR / f"{user}.pid"
    pids: set[int] = set()
    if pid_file.exists():
        try:
            pids.add(int(pid_file.read_text().strip()))
        except (ValueError, FileNotFoundError):
            pass

    # pgrep for any openconnect whose argv mentions this user (`-u <user>`
    # appears in the command line we spawn). pgrep -f matches against
    # full cmdline.
    try:
        out = subprocess.check_output(
            ["pgrep", "-f", f"openconnect.*-u {user}( |$)"], text=True
        )
        for line in out.split():
            line = line.strip()
            if line.isdigit():
                pids.add(int(line))
    except subprocess.CalledProcessError:
        pass  # no matches

    for pid in pids:
        try:
            os.kill(pid, 15)  # SIGTERM
        except ProcessLookupError:
            continue
    # Wait up to 10s for graceful exits, then SIGKILL stragglers.
    deadline = time.time() + 10.0
    while time.time() < deadline and pids:
        alive = set()
        for pid in pids:
            try:
                os.kill(pid, 0)
                alive.add(pid)
            except ProcessLookupError:
                pass
        if not alive:
            pids = alive
            break
        pids = alive
        time.sleep(0.5)
    for pid in pids:
        try:
            trace(f"kill_openconnect: SIGKILL stuck pid {pid}")
            os.kill(pid, 9)
        except ProcessLookupError:
            pass
    pid_file.unlink(missing_ok=True)


# ── per-netns resolv.conf cleanup ───────────────────────────────────
def cleanup_netns_resolvconf(ns: str):
    d = NETNS_ETC / ns
    (d / "resolv.conf").unlink(missing_ok=True)
    if d.exists() and not any(d.iterdir()):
        d.rmdir()


# ── socat L4 forwarders ─────────────────────────────────────────────
# For each entry in /etc/gpsaml-proxy/forwards.json we spawn a socat
# inside the user's netns. Because socat lives in the netns, its
# upstream connect() goes via tun0 (= via openconnect's VPN). The
# laptop side reaches it through the host-visible veth IP.
def load_forwards() -> list[dict]:
    if not FORWARDS_CONFIG.exists():
        return []
    try:
        data = json.loads(FORWARDS_CONFIG.read_text())
        return list(data.get("forwards", []))
    except (json.JSONDecodeError, OSError) as e:
        trace(f"load_forwards: failed to parse {FORWARDS_CONFIG}: {e}")
        return []


def _socat_pidfile(user: str, port: int) -> pathlib.Path:
    return RUNTIME_DIR / f"socat-{user}-{port}.pid"


def resolve_in_netns(ns: str, hostname: str):
    """Resolve hostname using the netns's resolv.conf (which points at
    the corp DNS pushed by openconnect). Returns None on failure."""
    try:
        res = subprocess.run(
            [IP, "netns", "exec", ns, "getent", "ahostsv4", hostname],
            capture_output=True, text=True, check=False, timeout=8,
        )
        if res.returncode != 0:
            return None
        # First column of first line is the IP.
        first = res.stdout.strip().split("\n")[0].split()
        if not first:
            return None
        return first[0]
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return None


def spawn_socats(user, ns, forwards_json):
    """Spawn one socat per forward, in the user's netns.

    forwards_json: JSON-encoded list of {hostname, port}. If None or
    empty falls back to /etc/gpsaml-proxy/forwards.json. Each hostname
    is resolved using corp DNS (via the netns's resolv.conf) — the
    extension only sends hostnames so the bastion is the
    trust-anchor for the IP.
    """
    if forwards_json:
        try:
            requested = json.loads(forwards_json)
        except json.JSONDecodeError:
            requested = []
    else:
        requested = load_forwards()

    # If the request didn't specify any forwards, fall back to the
    # static config (so admins can opt into a default).
    if not requested:
        requested = load_forwards()

    started: list[dict] = []
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    for fwd in requested:
        port = int(fwd["port"])
        # IP can come pre-resolved (legacy forwards.json) or be
        # resolved here from hostname (extension flow).
        ip = fwd.get("ip")
        if not ip:
            ip = resolve_in_netns(ns, fwd["hostname"])
            if not ip:
                trace(f"spawn_socats: skipping {fwd['hostname']}: DNS resolve failed in netns")
                continue
        cmd = [
            IP, "netns", "exec", ns,
            SOCAT,
            f"TCP-LISTEN:{port},fork,reuseaddr,bind=0.0.0.0",
            f"TCP:{ip}:{port}",
        ]
        trace(f"spawn_socats: starting forward {fwd['hostname']} -> {ip}:{port}")
        proc = subprocess.Popen(
            cmd,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            close_fds=True,
            start_new_session=True,
        )
        _socat_pidfile(user, port).write_text(str(proc.pid))
        started.append({"hostname": fwd["hostname"], "ip": ip, "port": port, "pid": proc.pid})
    return started


def kill_socats(user: str):
    """Kill all socat forwarders for this user. Pidfiles are
    authoritative; pkill is a fallback in case the pidfile got out
    of sync (subprocess timeouts, crashes)."""
    for pf in RUNTIME_DIR.glob(f"socat-{user}-*.pid"):
        try:
            pid = int(pf.read_text().strip())
            try:
                os.kill(pid, 15)
            except ProcessLookupError:
                pass
        except (ValueError, OSError):
            pass
        pf.unlink(missing_ok=True)
    # Belt and suspenders: any socat we lost track of, find by argv.
    try:
        ns = ns_for(user)
        subprocess.run(
            ["pkill", "-f", f"netns exec {ns}.*socat"],
            check=False, capture_output=True,
        )
    except FileNotFoundError:
        pass


# ── top-level commands ──────────────────────────────────────────────
def cmd_up(user: str, cookie: str, gateway: str, fingerprint: str,
           forwards_json=None):
    trace(f"cmd_up: start user={user} gateway={gateway}")
    assert_user(user)
    ensure_group()
    ensure_user(user)

    # Idempotency: if a previous `up` was interrupted (gunicorn timeout,
    # cookie reject, segfault…) it can leave a half-built ns + a stranded
    # openconnect process behind. Tearing down first guarantees a clean
    # slate; cmd_down is itself a no-op when nothing is running.
    trace("cmd_up: cleanup stale state")
    cmd_down(user)

    trace("cmd_up: acquire subnet")
    octet, host_ip, ns_ip = acquire_subnet(user)
    ns = ns_for(user)

    trace(f"cmd_up: setup netns/veth/nat (ns={ns} octet={octet})")
    ensure_ip_forward()
    ensure_netns(ns)
    setup_veth(user, ns, host_ip, ns_ip)
    ensure_nat(octet)

    trace("cmd_up: gen keypair + write authorized_keys + sudoers")
    priv_key, pub_key = gen_keypair(user)
    write_authorized_keys(user, pub_key, ns)
    write_sudoers(user, ns)

    ok = spawn_openconnect(user, ns, cookie, gateway, fingerprint)
    if not ok:
        # tunnel didn't come up — best-effort rollback so a retry is clean
        trace("cmd_up: spawn_openconnect failed; rolling back")
        cmd_down(user)
        sys.exit("openconnect failed to bring tunnel up within deadline")

    trace("cmd_up: spawn socat forwarders")
    forwards = spawn_socats(user, ns, forwards_json)

    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    (RUNTIME_DIR / f"{user}.alive").touch()

    trace("cmd_up: done, writing JSON envelope to stdout")
    # JSON envelope: { "private_key": "...", "ns_ip": "...",
    # "forwards": [{hostname, ip, port}, ...] }. Web parses this
    # and feeds it into the .command builder; older "raw key on
    # stdout" callers should be migrated.
    envelope = {
        "private_key": priv_key,
        "ns_ip": ns_ip,
        "forwards": [
            {"hostname": f["hostname"], "ip": f["ip"], "port": int(f["port"])}
            for f in forwards
        ],
    }
    sys.stdout.write(json.dumps(envelope))


def cmd_down(user: str):
    trace(f"cmd_down: start user={user}")
    assert_user(user)
    ns = ns_for(user)

    kill_socats(user)
    kill_openconnect(user)
    trace("cmd_down: socat + openconnect killed; tearing down netns/veth/nat")
    cleanup_netns_resolvconf(ns)
    del_netns(ns)
    remove_veth(user)

    octet = lookup_subnet(user)
    if octet is not None:
        remove_nat(octet)
    release_subnet(user)

    remove_sudoers(user)
    blank_authorized_keys(user)

    (RUNTIME_DIR / f"{user}.alive").unlink(missing_ok=True)


def cmd_heartbeat(user: str):
    assert_user(user)
    p = RUNTIME_DIR / f"{user}.alive"
    if not p.exists():
        sys.exit(f"no active session for {user}")
    p.touch()


def cmd_list():
    """Print active sessions (for the reaper / admin debugging)."""
    if not RUNTIME_DIR.exists():
        return
    now = time.time()
    for f in RUNTIME_DIR.glob("*.alive"):
        user = f.stem
        age = int(now - f.stat().st_mtime)
        print(f"{user}\t{age}s")


def main():
    p = argparse.ArgumentParser()
    sub = p.add_subparsers(dest="cmd", required=True)

    up = sub.add_parser("up")
    up.add_argument("user")
    up.add_argument("cookie")
    up.add_argument("gateway")
    up.add_argument("fingerprint")
    up.add_argument(
        "forwards",
        nargs="?",
        default=None,
        help="JSON-encoded list of {hostname, port} forwards",
    )

    dn = sub.add_parser("down")
    dn.add_argument("user")

    hb = sub.add_parser("heartbeat")
    hb.add_argument("user")

    sub.add_parser("list")

    args = p.parse_args()
    if os.geteuid() != 0:
        sys.exit("provision must run as root")

    if args.cmd == "up":
        cmd_up(args.user, args.cookie, args.gateway, args.fingerprint, args.forwards)
    elif args.cmd == "down":
        cmd_down(args.user)
    elif args.cmd == "heartbeat":
        cmd_heartbeat(args.user)
    elif args.cmd == "list":
        cmd_list()


if __name__ == "__main__":
    main()
