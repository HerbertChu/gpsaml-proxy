#!/bin/sh
# enter-ns — invoked by sshd as the user (via authorized_keys
# command="...") to push the SSH session into the user's network
# namespace before exec'ing whatever the client asked to run.
#
# The client's command lands in $SSH_ORIGINAL_COMMAND. sshuttle's
# remote-end invocation looks like a long python -c blob; we shove
# that into the namespace verbatim. If the client connected with no
# command at all, refuse — we don't want this to look like an
# interactive shell.
#
# Privilege escalation: this runs as the SSH user, but `ip netns exec`
# requires root. /etc/sudoers.d/gpsaml-user-<user> grants the user a
# tightly-scoped NOPASSWD entry for *only* `ip netns exec ns_<user> *`,
# generated by `provision up`.

set -e

NS="${1:?missing namespace argument}"

if [ -z "${SSH_ORIGINAL_COMMAND-}" ]; then
  echo "gpsaml-proxy: interactive shells are not permitted" >&2
  exit 1
fi

# Pin to the namespace and re-exec the client's command. Using /bin/sh
# rather than execing $SSH_ORIGINAL_COMMAND directly lets sshuttle's
# pipeline expand naturally (it sometimes ships a here-doc-style command
# with quoting we shouldn't second-guess).
exec sudo -n /usr/sbin/ip netns exec "$NS" /bin/sh -c "$SSH_ORIGINAL_COMMAND"
