#!/bin/sh
# enter-ns — invoked by sshd as the user (via authorized_keys
# command="…") to push the SSH session into the user's network
# namespace before exec'ing whatever the client asked to run.
#
# The privilege dance in this script:
#
#   1. sshd executes us as the unprivileged ssh user.
#   2. We `sudo` (NOPASSWD-restricted to a single ns by sudoers) to gain
#      root just long enough to call `ip netns exec`, which moves the
#      following process into the per-user namespace.
#   3. Inside the namespace we IMMEDIATELY `setpriv` back down to the
#      original UID/GID and clear inheritable capabilities, so the
#      client's command runs as the user — not as root. This is what
#      keeps `cat /etc/shadow` and `sudo ip netns exec ns_other_user`
#      from working: by the time the client's shell runs, we no longer
#      have privilege.
#
# The sudoers rule (`hc1079 ALL=(root) NOPASSWD: /usr/sbin/ip netns
# exec ns_hc1079 *`) only constrains step 2 — the wildcard happily
# matches the long setpriv invocation we hand to it; security depends
# on step 3 dropping us back to the user before any client code runs.

set -e

NS="${1:?missing namespace argument}"

if [ -z "${SSH_ORIGINAL_COMMAND-}" ]; then
  echo "gpsaml-proxy: interactive shells are not permitted" >&2
  exit 1
fi

USER_UID=$(id -u)
USER_GID=$(id -g)

exec sudo -n /usr/sbin/ip netns exec "$NS" \
  /usr/bin/setpriv \
    --reuid="$USER_UID" \
    --regid="$USER_GID" \
    --clear-groups \
    --inh-caps=-all \
  /bin/sh -c "$SSH_ORIGINAL_COMMAND"
